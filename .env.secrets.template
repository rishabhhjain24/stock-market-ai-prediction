# ════════════════════════════════════════════════════════════════════════════════
# 1. For Streamlit Cloud Deployment
# ════════════════════════════════════════════════════════════════════════════════
# File: .streamlit/secrets.toml (create this locally for testing)
# In Streamlit Cloud, add these in: Settings → Secrets

gemini_api_key = "your-gemini-api-key-here"
newsapi_key = "your-newsapi-key-here"

# Optional: If using custom API
openai_api_key = "your-openai-key-if-needed"

# ════════════════════════════════════════════════════════════════════════════════
# 2. For Railway/Heroku Environment Variables
# ════════════════════════════════════════════════════════════════════════════════

# Set these as environment variables:
# Railway CLI: railway variable add KEY value
# Heroku CLI: heroku config:set KEY=value

GEMINI_API_KEY=your-gemini-api-key-here
NEWSAPI_KEY=your-newsapi-key-here
OPENAI_API_KEY=your-openai-key-if-needed

# ════════════════════════════════════════════════════════════════════════════════
# 3. For Local Testing (.env file)
# ════════════════════════════════════════════════════════════════════════════════
# Create: .env (in project root, NOT in GitHub)
# Make sure .gitignore has: .env

GEMINI_API_KEY=your-gemini-api-key-here
NEWSAPI_KEY=your-newsapi-key-here

